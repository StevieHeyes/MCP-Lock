# Rust build artifacts
/target
**/*.rs.bk

# Cargo lock is committed for the workspace (this repo produces binaries, not a
# published library), so it is intentionally NOT ignored.

# Local environment / secrets — never commit. MCP-Lock takes credentials only
# from the environment or the platform key store; nothing secret belongs here.
.env
.env.*
*.pem
*.key
*.p12
*.keychain

# Editor / OS noise
.DS_Store
*.swp
.idea/
.worktrees/

# VS Code: commit the shared project config, ignore user-specific/local files.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
